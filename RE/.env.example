# LOGH VII 서버 환경설정 예시.
#
# 사용법: 이 파일을 `.env`로 복사한 뒤 바꾸고 싶은 값만 주석 해제/수정한다.
# 우선순위: 실제 셸 env > `.env` 파일 > 코드의 playable 기본값(src/server/logh7-config.mjs).
# 아무것도 안 해도 `npm start`만으로 플레이 가능한 서버가 뜬다 — `.env`는 "기본값을 덮어쓰고 싶을 때"만.

# --- 네트워크/부팅 ---
# 설치된 클라 EXE 경로(child-codec 암호 테이블 추출용). 기본: .omo/work/logh7-installed/exe/G7MTClient.exe
#LOGH_CLIENT_EXE=

# --- 콘텐츠/현지화 (기본 on) ---
#LOGH_CONTENT_DB=1        # 추출된 콘텐츠 DB 사용
#LOGH_KO_NAMES=1          # 한글 이름
#LOGH_MODS_DIR=mods       # 모드 오버레이 디렉터리

# --- authoritative 멀티플레이 (기본 on) ---
#LOGH_RELAY=1
#LOGH_AUTHORITATIVE=1

# --- 전략맵 (기본 on) ---
#LOGH_STRAT_GALAXY=1      # 캐논 80성계
#LOGH_STRAT_GRID=1        # 100x50 섹터 그리드
#LOGH_STRAT_TERRAIN=1     # 지형 인코딩(空間/航行不能/プラズマ嵐)
#LOGH_STRAT_FLEET=1       # 플레이어 함대 클릭 마커

# --- 계정 영속성 (기본: accept-any-GIN7) ---
#LOGH_ACCOUNT_DB=.omo/state/accounts.json
#LOGH_ACCOUNT_DB_ALLOW_REGISTER=1   # 최초 로그인 시 가입 허용(TOFU)

# --- 무유저 시뮬/AI (기본 off) ---
#LOGH_STRAT_SIM=1
#LOGH_NPC_SEED=1
#LOGH_NPC_AI=1

# 전체 플래그 목록은 src/server/logh7-config.mjs 참조.
