{
  "name": "logh-7-rework",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node src/server/logh7-server.mjs serve-auth",
    "start:nest": "node --import tsx src/app/main.ts",
    "server:logh7": "node src/server/logh7-server.mjs serve",
    "server:gameplay": "node src/server/logh7-server.mjs serve-gameplay",
    "server:auth": "node src/server/logh7-server.mjs serve-auth",
    "server:health": "node src/server/logh7-server.mjs health",
    "test:server": "node --test tests/server/*.test.mjs",
    "test:drizzle": "node --import tsx --test \"tests/server/drizzle/**/*.test.ts\"",
    "test:tools": "node tools/run_python_tests.mjs",
    "test": "npm run test:tools && npm run test:server && playwright test",
    "doctor": "npx react-doctor@latest",
    "headroom:proxy": "docker run --rm -p 8787:8787 ghcr.io/chopratejas/headroom:latest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@vitejs/plugin-react": "^4.5.2",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "headroom-ai": "^0.22.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "react-doctor": "^0.5.7",
    "react-grab": "^0.1.47",
    "react-scan": "^0.5.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
