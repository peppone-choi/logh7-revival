{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/turn-snapshot.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/stop-doc-gate.sh",
            "timeout": 30,
            "statusMessage": "문서 현행화 게이트 검사 중"
          }
        ]
      }
    ]
  }
}
