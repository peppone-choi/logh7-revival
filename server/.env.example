# LOGH VII server override sample.
#
# Normal use needs no values here. `npm start` already uses:
# - account DB: state/accounts.sqlite
# - session DB: logh7-runtime/state/lobby-sessions.sqlite
# - public signup: http://127.0.0.1:47901/signup
# - server name/session: 이제르론 서버
#
# Leave this file empty unless a deployment explicitly needs overrides.
