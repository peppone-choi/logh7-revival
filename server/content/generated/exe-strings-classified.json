  "place_name_candidate": {
   "count": 31,
   "examples": [
    {
     "offset_hex": "0x371250",
     "encoding": "cp932",
     "section": ".data",
     "text": "惑星を検出出来なかった、バグでしょう"
    },
    {
     "offset_hex": "0x371dec",
     "encoding": "cp932",
     "section": ".data",
     "text": "要塞"
    },
    {
     "offset_hex": "0x371df4",
     "encoding": "cp932",
     "section": ".data",
     "text": "惑星"
    },
    {
     "offset_hex": "0x384ea8",
     "encoding": "cp932",
     "section": ".data",
     "text": "惑星を複数は選択できない仕様ですので"
    },
    {
     "offset_hex": "0x38bbfb",
     "encoding": "cp932",
     "section": ".data",
     "text": "宇宙空間にいる場合は、まず星系グリッドの拠点に向かって航行してください。"
    },
    {
     "offset_hex": "0x38bce5",
     "encoding": "cp932",
     "section": ".data",
     "text": "宇宙空間にいる場合は、まず星系グリッドの拠点に向かって航行してください。"
    },
    {
     "offset_hex": "0x38be7f",
     "encoding": "cp932",
     "section": ".data",
     "text": "選択可能な拠点のある星系グリッドにワープしてください。"
    },
    {
     "offset_hex": "0x38c6d0",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星&直轄封土の惑星"
    },
    {
     "offset_hex": "0x38c7b0",
     "encoding": "utf16le",
     "section": ".data",
     "text": "惑星/要塞に存在するスポット＆警戒スポット"
    },
    {
     "offset_hex": "0x38c9d4",
     "encoding": "utf16le",
     "section": ".data",
     "text": "＜'輸送先惑星名'用＞"
    },
    {
     "offset_hex": "0x38ca8c",
     "encoding": "utf16le",
     "section": ".data",
     "text": "当該惑星に在庫の輸送パッケージ&選択惑星が輸送先に設定されているパッケージ"
    },
    {
     "offset_hex": "0x38cbb8",
     "encoding": "utf16le",
     "section": ".data",
     "text": "選択惑星/要塞にある部隊用ストック"
    },
    {
     "offset_hex": "0x38cbdc",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞&同星系内に敵陣惑星/要塞無し&軍需物資/いずれかのユニットを在庫"
    },
    {
     "offset_hex": "0x38cc34",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同一惑星/要塞に存在する人物"
    },
    {
     "offset_hex": "0x38cde4",
     "encoding": "utf16le",
     "section": ".data",
     "text": "惑星/要塞に存在する施設"
    },
    {
     "offset_hex": "0x38ce00",
     "encoding": "utf16le",
     "section": ".data",
     "text": "他陣営の惑星/要塞&コマンド実行星系から1000光年以内&コマンド実行星系から1000光年以内にフェザーン有りの場合"
    },
    {
     "offset_hex": "0x38ce98",
     "encoding": "utf16le",
     "section": ".data",
     "text": "自陣営の惑星/要塞&コマンド実行星系から1000光年以内&コマンド実行星系から1000光年以内にフェザーン有りの場合"
    },
    {
     "offset_hex": "0x38d0bc",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞&封土以外"
    },
    {
     "offset_hex": "0x38d0dc",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞"
    },
    {
     "offset_hex": "0x38d0f0",
     "encoding": "utf16le",
     "section": ".data",
     "text": "非逮捕者&弁明を選択済みの人物&同惑星の拘禁室に存在"
    },
    {
     "offset_hex": "0x38d17c",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞&統治目標を掲げていない惑星/要塞&封土以外"
    },
    {
     "offset_hex": "0x38d1d0",
     "encoding": "utf16le",
     "section": ".data",
     "text": "自陣と敵陣惑星の混在する星系&コマンド実行星系より500光年以内"
    },
    {
     "offset_hex": "0x38d308",
     "encoding": "utf16le",
     "section": ".data",
     "text": "選択惑星/要塞の在庫が部隊枠の下限数以上＆"
    },
    {
     "offset_hex": "0x38d35c",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星＆同陣営の要塞＆同星系内に敵陣惑星無し＆同星系内に敵陣要塞無し＆"
    },
    {
     "offset_hex": "0x38d3d0",
     "encoding": "utf16le",
     "section": ".data",
     "text": "いずれかの惑星/要塞駐留中の部隊&いずれのキャラも属していない状態の部隊"
    },
    {
     "offset_hex": "0x38d41c",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞&同星系内に敵陣惑星/要塞無し"
    },
    {
     "offset_hex": "0x38d450",
     "encoding": "utf16le",
     "section": ".data",
     "text": "同陣営の惑星/要塞&同星系内に敵陣惑星/要塞無し&輸送元に指定されていない"
    },
    {
     "offset_hex": "0x38d4ac",
     "encoding": "cp932",
     "section": ".data",
     "text": "星系内宇宙"
    },
    {
     "offset_hex": "0x38d4c8",
     "encoding": "cp932",
     "section": ".data",
     "text": "%s星系"
    },
    {
     "offset_hex": "0x38d6ec",
     "encoding": "cp932",
     "section": ".data",
     "text": "サーバーログがヌルで返りました(星系内航行)"
    },
    {
     "offset_hex": "0x38d9a8",
     "encoding": "utf16le",
     "section": ".data",
     "text": "自由惑星同盟"
    }
   ]
  },
