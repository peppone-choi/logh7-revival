  "abilities": [
    {
      "name_ja": "統率",
      "effect": "人材活用能力。要職就任時は徴税額・政府支持率に影響。艦隊司令官時は艦隊最大士気・降伏勧告成功率に影響"
    },
    {
      "name_ja": "政治",
      "effect": "政治力。高いほど市民の支持を集めやすい"
    },
    {
      "name_ja": "運営",
      "effect": "事務管理能力。惑星の統治などに影響"
    },
    {
      "name_ja": "情報",
      "effect": "情報収集・分析能力。スパイ活動や戦術における索敵能力に影響"
    },
    {
      "name_ja": "指揮",
      "effect": "部隊指揮能力。高いほど配下の艦船を迅速に行動させられる"
    },
    {
      "name_ja": "機動",
      "effect": "艦隊移動に関する指揮能力。高いほど機敏な操艦が可能"
    },
    {
      "name_ja": "攻撃",
      "effect": "攻撃に関する指揮能力。艦隊司令官/幕僚時は艦隊の攻撃能力、惑星防衛司令官時は惑星の対艦防衛能力に影響"
    },
    {
      "name_ja": "防御",
      "effect": "防御に関する指揮能力。艦隊司令官/幕僚時は艦隊の防御能力、防衛司令官時は敵艦隊の惑星占領に対する惑星防御能力に影響"
    }
  ],
