  "mechanics": [
    {
      "id": "original_character_lottery_confirmed",
      "claim": "Original/canon characters were not just selected freely; they used a draw/lottery flow when contested.",
      "evidence": [
        {
          "source_id": "itmedia_2003_09_25",
          "local_lines": "115-116",
          "summary": "Official preview says accumulated points allow original-character play for one session, and high-demand characters are decided by lottery."
        },
        {
          "source_id": "noweuncle_no_36",
          "local_lines": "36-42",
          "summary": "Korean CBT player reports selecting Mecklinger and winning that character."
        },
        {
          "source_id": "noweuncle_no_5",
          "local_lines": "36-66",
          "summary": "Korean CBT player reports being stuck after applying for an existing/canon character and asks when the draw will finish."
        },
        {
          "source_id": "noweuncle_no_122",
          "local_lines": "50-56",
          "summary": "Patch note changes original-character draw interval from 12 hours to 3 hours and fixes a draw-cancel character-creation bug."
        }
      ]
    },
    {
      "id": "unselected_originals_as_ai",
      "claim": "At least some community testers expected unselected original/canon characters to remain active as AI/NPCs, then transfer to users if won later.",
      "evidence": [
        {
          "source_id": "noweuncle_no_113",
          "local_lines": "48-50",
          "summary": "Feedback proposes fame/merit gating for draw and AI control for unselected original characters."
        }
      ]
    },
    {
      "id": "five_choice_draw_ui",
      "claim": "Japanese beta draw UI accepted first through fifth desired character choices.",
      "evidence": [
        {
          "source_id": "rap_ar102364",
          "local_lines": "124-132",
          "summary": "Player recollection says they filled first to fifth choices with Reinhard and became Reinhard von Lohengramm."
        }
      ]
    }
  ],
