# 원본 CD 이미지 (218MB, GitHub 한도 초과 — archive.org에서 재다운로드 가능)
/artifacts/

# 외부 참고 레포 (방법론 검토용, 라이선스가 다른 코드는 이식하지 않음)
/reference/

# 훅/플러그인 런타임 상태 (자동 재생성)
/.omc/
/server/.omc/
/.bkit/

# CodeGraph 인덱스 (codegraph init로 재생성)
/.codegraph/

# 의존성/빌드/캐시
node_modules/
dist/
build/
__pycache__/
*.pyc

# 런타임 상태 / 비밀
.env
*.sqlite
*.sqlite-shm
*.sqlite-wal
.aider*
